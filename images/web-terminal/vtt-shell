#!/usr/bin/env bash
# ABOUTME: ttyd launch shim. Attaches the browser terminal to a NAMED tmux session so a refresh or a
# ABOUTME: dropped connection resumes the SAME session (running claude, scrollback, cwd) rather than a
# ABOUTME: fresh shell. The session name arrives from the URL (?arg=<name>, passed by ttyd -a); sanitized.
set -euo pipefail

raw="${1:-main}"
# Only [A-Za-z0-9-], capped, so a client-supplied arg can never be more than a session name.
name="$(printf '%s' "${raw}" | tr -cd 'a-zA-Z0-9-' | cut -c1-32)"
[[ -z "${name}" ]] && name="main"

# -A: attach if the session exists, otherwise create it. Persistence falls out of this: the tmux server
# outlives any single websocket, so the next connection re-attaches to the still-running session.
exec tmux new-session -A -s "${name}"
