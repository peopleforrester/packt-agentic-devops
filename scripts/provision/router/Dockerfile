# ABOUTME: The fleet router: Caddy mapping each studentN hostname to that cluster's NLB.
# ABOUTME: Caddyfile is generated by `fleet.sh routes` before every deploy, never edited by hand.
FROM caddy:2-alpine

COPY Caddyfile /etc/caddy/Caddyfile
COPY srv/ /srv/

# Fail the build rather than the deploy if the generated routing table is malformed. A router that
# boots with a broken config takes every student offline at once.
RUN caddy validate --config /etc/caddy/Caddyfile --adapter caddyfile

CMD ["caddy", "run", "--config", "/etc/caddy/Caddyfile", "--adapter", "caddyfile"]
